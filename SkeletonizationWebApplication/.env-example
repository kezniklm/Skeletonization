# ===========================================
# Storage Configuration
# ===========================================

# Backend: "local" (default) or "s3"
STORAGE_BACKEND=local

# Used only when STORAGE_BACKEND=local
PUBLIC_UPLOADS_DIR=uploads

# ===========================================
# S3 / Cloudflare R2 Configuration (Required when STORAGE_BACKEND=s3)
# ===========================================
S3_ENDPOINT=
S3_REGION=auto
S3_BUCKET=images
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_FORCE_PATH_STYLE=true

# ===========================================
# Database (PostgreSQL)
# ===========================================
DATABASE_URL=

# ===========================================
# Redis
# ===========================================
REDIS_URL=

# ===========================================
# Authentication (Better Auth)
# ===========================================
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=

# ===========================================
# Google OAuth
# ===========================================
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
